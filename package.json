{
  "name": "@veedubin/boomerang-v3",
  "version": "0.4.0",
  "description": "Multi-agent orchestration plugin for OpenCode with memini-ai memory",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "boomerang-setup": "./scripts/install-boomerang.js"
  },
  "files": [
    "dist/",
    "scripts/",
    ".opencode/",
    "AGENTS.md",
    "package.json",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Veedubin/Boomerang-v3"
  },
  "homepage": "https://github.com/Veedubin/Boomerang-v3#readme",
  "bugs": {
    "url": "https://github.com/Veedubin/Boomerang-v3/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.30.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
